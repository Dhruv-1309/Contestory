<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.CPContestTracker" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">true</item>

        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorOnPrimary">@color/text_primary</item>

        <item name="android:fontFamily">sans-serif-medium</item>

        <item name="bottomNavigationStyle">@style/Widget.App.BottomNavigationView</item>
    </style>

    <style name="Widget.App.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/bg_card</item>
        <item name="itemIconTint">@color/selector_nav_item</item>
        <item name="itemTextColor">@color/selector_nav_item</item>
        <item name="itemRippleColor">@color/accent_purple_muted</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.App.BottomNavigationView.Indicator</item>
        <item name="itemBackground">@drawable/bg_nav_item</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">0dp</item>
        <item name="itemPaddingTop">6dp</item>
        <item name="itemPaddingBottom">6dp</item>
        <item name="itemIconSize">22dp</item>
        <item name="itemTextAppearanceActive">@style/Widget.App.BottomNavigationView.Label.Active</item>
        <item name="itemTextAppearanceInactive">@style/Widget.App.BottomNavigationView.Label.Inactive</item>
    </style>

    <style name="Widget.App.BottomNavigationView.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@android:color/transparent</item>
        <item name="android:width">24dp</item>
        <item name="android:height">24dp</item>
    </style>

    <style name="Widget.App.BottomNavigationView.Label.Active" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.App.BottomNavigationView.Label.Inactive" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
</resources>
