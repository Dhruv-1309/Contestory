<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/currentDateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="Saturday, May 16" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/appLogo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/text_primary"
                android:textSize="30sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Theme Toggle Button -->
            <ImageButton
                android:id="@+id/themeToggleButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_notification_circle"
                android:contentDescription="Toggle Theme"
                android:padding="11dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_theme_toggle"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/notificationButton"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/text_primary" />

            <!-- Notification Button -->
            <ImageButton
                android:id="@+id/notificationButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_notification_circle"
                android:contentDescription="Notifications"
                android:padding="11dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_bell"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/text_primary" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <!-- Main Content Container -->
    <FrameLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationCard"
        app:layout_constraintTop_toBottomOf="@id/headerContainer">

        <!-- Screen 1: Home Screen -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/homeLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="24dp">

                <!-- Stale data banner — shown when the UI is displaying cached data
                     after a network failure. GONE by default; visibility controlled
                     by ContestViewModel.isUsingCachedData. Tapping triggers a refresh. -->
                <TextView
                    android:id="@+id/staleBanner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/accent_purple_muted"
                    android:gravity="center"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="16dp"
                    android:text="@string/stale_data_banner"
                    android:textColor="@color/accent_purple"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <!-- Day Selector Chips -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/dayChipGroup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="8dp"
                        app:chipSpacingHorizontal="10dp"
                        app:selectionRequired="true"
                        app:singleSelection="true" />
                </HorizontalScrollView>

                <!-- Platform Selector Chips -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/platformChipGroup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="8dp"
                        app:chipSpacingHorizontal="8dp" />
                </HorizontalScrollView>

                <!-- Live Now Section -->
                <TextView
                    android:id="@+id/liveNowLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="20dp"
                    android:letterSpacing="0.1"
                    android:text="@string/live_now_section"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/liveRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false"
                    android:paddingHorizontal="4dp"
                    tools:listitem="@layout/item_contest" />

                <!-- Upcoming Section -->
                <TextView
                    android:id="@+id/upcomingLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="20dp"
                    android:letterSpacing="0.1"
                    android:text="@string/upcoming_today_section"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/upcomingRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false"
                    android:paddingHorizontal="4dp"
                    tools:listitem="@layout/item_contest" />

                <!-- Home Empty State — shown when no contests are visible for the selected day -->
                <LinearLayout
                    android:id="@+id/homeEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="48dp"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingHorizontal="32dp"
                    android:visibility="gone">

                    <!-- Icon -->
                    <ImageView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:alpha="0.35"
                        android:src="@drawable/ic_timer"
                        android:contentDescription="No contests"
                        app:tint="@color/accent_purple" />

                    <!-- Primary message -->
                    <TextView
                        android:id="@+id/homeEmptyTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center"
                        android:text="No contests scheduled"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <!-- Secondary message -->
                    <TextView
                        android:id="@+id/homeEmptySubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.4"
                        android:text="No contests are scheduled on this day."
                        android:textColor="@color/text_muted"
                        android:textSize="14sp" />

                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Screen 2: Schedule Screen -->
        <include
            android:id="@+id/scheduleLayout"
            layout="@layout/activity_schedule"
            android:visibility="gone" />

        <!-- Screen 3: Reminders Screen -->
        <include
            android:id="@+id/remindersLayout"
            layout="@layout/activity_reminders"
            android:visibility="gone" />

        <!-- Screen 4: Settings Screen -->
        <include
            android:id="@+id/settingsLayout"
            layout="@layout/activity_settings"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Floating Bottom Navigation -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavigationCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="10dp"
        app:strokeColor="@color/border"
        app:strokeWidth="1dp"
        app:cardBackgroundColor="@color/bg_card"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            app:menu="@menu/bottom_nav_menu"
            style="@style/Widget.App.BottomNavigationView"
            app:paddingBottomSystemWindowInsets="false" />
    </com.google.android.material.card.MaterialCardView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="@color/accent_purple"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
