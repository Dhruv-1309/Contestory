<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/border"
    app:strokeWidth="1.2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Top Row: Platform Badge and Live Badge -->
        <LinearLayout
            android:id="@+id/badgeRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:id="@+id/platformBadgeContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge"
                android:backgroundTint="@color/platform_codeforces_bg"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp">

                <ImageView
                    android:id="@+id/platformLogo"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_code" />

                <TextView
                    android:id="@+id/platformBadgeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="@color/accent_purple_light"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="Codeforces" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Live Status Badge -->
            <LinearLayout
                android:id="@+id/liveBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge"
                android:backgroundTint="@color/live_green_bg"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:visibility="gone"
                tools:visibility="visible">

                <!-- Redesigned pulsing/solid live indicator dot -->
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_notification_circle"
                    android:backgroundTint="@color/live_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="LIVE"
                    android:textColor="@color/live_green"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Contest Name -->
        <TextView
            android:id="@+id/contestNameText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/badgeRow"
            tools:text="Codeforces Round 1023 (Div. 2)" />

        <!-- Metadata Section (Time range & Duration) -->
        <LinearLayout
            android:id="@+id/metaContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/contestNameText">

            <!-- Time range -->
            <TextView
                android:id="@+id/timeRangeText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawablePadding="6dp"
                android:gravity="center_vertical"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                app:drawableStartCompat="@drawable/ic_clock"
                app:drawableTint="@color/text_muted"
                tools:text="Ends at 11:35 PM" />

            <!-- Duration -->
            <TextView
                android:id="@+id/durationText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawablePadding="6dp"
                android:gravity="center_vertical"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginStart="16dp"
                app:drawableStartCompat="@drawable/ic_clock"
                app:drawableTint="@color/text_muted"
                tools:text="2h 15m" />

        </LinearLayout>

        <!-- Bottom Action Row -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/metaContainer">

            <!-- Redesigned Countdown Capsule Timer -->
            <LinearLayout
                android:id="@+id/countdownPill"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_countdown_box"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/timerIcon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_timer"
                    app:tint="@color/accent_purple"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/hoursBox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    tools:text="02" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent_purple"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="8dp"
                    android:text="H" />

                <TextView
                    android:id="@+id/minutesBox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    tools:text="45" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent_purple"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="8dp"
                    android:text="M" />

                <TextView
                    android:id="@+id/secondsBox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    tools:text="12" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent_purple"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="2dp"
                    android:text="S" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/openContestButton"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="16dp"
                android:text="Register"
                android:textAllCaps="false"
                android:textColor="@color/accent_purple"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_open_in_browser"
                app:iconGravity="textStart"
                app:iconSize="16dp"
                app:iconTint="@color/accent_purple"
                app:backgroundTint="@color/accent_purple_muted"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:strokeColor="@color/accent_purple"
                app:strokeWidth="1dp" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
